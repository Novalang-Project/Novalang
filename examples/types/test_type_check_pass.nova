// Test auto type inference
auto a = [2,5,2,6]
println(a)

// Test int type
int b = 42
println(b)

// Test string type
string c = "hello"
println(c)

// Test bool type
bool d = true
println(d)

// Test float type
float e = 3.14
println(e)

// Test int with float (allowed - int can be assigned to float)
float f = 10
println(f)

// Test list type
list g = [1, 2, 3]
println(g)

// Test auto with string
auto h = "world"
println(h)
