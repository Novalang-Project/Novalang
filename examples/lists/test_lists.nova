# Test list functionality in NovaLang

# Test 1: Basic list literal
list nums = [1, 2, 3]
println(nums[0])
println(nums[1])
println(nums[2])


# Test 2: List indexing with assignment
nums[1] = 5

println(nums[1])


# Test 3: len() function
len(nums)

# Test 4: push() function
push(nums, 10)
println(nums)

# Test 5: pop() function
pop(nums)
println(nums)

# Test 6: Empty list
list empty = []
len(empty)

# Test 7: Negative indices
println(nums[-1])
println(nums[-2])

# Test 8: Nested list operations
list matrix = [[1, 2], [3, 4]]
len(matrix)

println(matrix[0])
println(matrix[0][0])


# Test 9: List with different types
list mixed = [1, "hello", true]
len(mixed)

println(mixed[0])
println(mixed[1])
println(mixed[2])
